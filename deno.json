{
  "name": "@devcapsule/adapter",
  "version": "3.3.2",
  "license": "ISC",
  "description": "Empowering Next-Generation UI Style with ES6 and WebComponent",
  "tasks": {
    "docs:sync-skill-references": "uv run python dev/cli.py docs skill-sync",
    "docs:build": "uv run python dev/cli.py docs build",
    "docs:publish": "uv run python dev/cli.py docs publish",
    "docs:serve": "uv run python dev/cli.py docs serve",
    "test:esbuild": "deno run --watch-hmr --allow-all ./esbuild/test.js",
    "test:html": "engrave server test-src/ docs/test/ --watch-add='.*.js'",
    "test": "deno task test:esbuild & deno task test:html",
    "dist:types": "npx tsc --project tsconfig.json",
    "dist:js": "deno run --allow-all esbuild/dist.js",
    "dist": "deno task dist:types & deno task dist:js",
    "publish": "deno publish --allow-slow-types --allow-dirty"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "dom.asynciterable",
      "deno.ns",
      "deno.unstable"
    ]
  },
  "unstable": ["sloppy-imports"],
  "lint": {
    "rules": {
      "exclude": ["no-sloppy-imports"]
    }
  },
  "publish": {
    "include": [
      "src/",
      "dist/browser/",
      "dist/node/",
      "src/agent-skills/",
      "README.md",
      "LICENSE.md"
    ]
  },
  "exports": {
    ".": "./src/mod.ts",
    "./adapter-skill-install": "./src/adapter-skill-install.ts"
  },
  "imports": {
    "@cliffy/command": "jsr:@cliffy/command@^1.0.1",
    "@devcapsule/adapter": "./src/mod.ts",
    "@std/fs": "jsr:@std/fs@^1.0.20",
    "@std/path": "jsr:@std/path@^1.1.3",
    "esbuild": "https://deno.land/x/esbuild@v0.27.0/mod.js"
  }
}
